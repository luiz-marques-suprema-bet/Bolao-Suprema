# ── Supabase (obrigatório em produção) ───────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Modo mock (desenvolvimento sem Supabase) ──────────────────
# VITE_MOCK_AUTH=true

# ── GIFs na Resenha (Tenor API) ───────────────────────────────
# Sem chave: GIFs desabilitados
# VITE_TENOR_KEY=your-tenor-api-key

# ── Busca de jogadores no Perfil (TheSportsDB) ────────────────
# Sem chave: usa chave free '123' (rate-limited)
# VITE_THESPORTSDB_KEY=your-thesportsdb-key

# ── Notícias Copa 2026 na Home (Football News API via RapidAPI) ─
# Sem chave: seção de notícias não aparece
# VITE_FNEWS_URL=https://football-news-aggregator-live.p.rapidapi.com
# VITE_FNEWS_KEY=your-rapidapi-key
# VITE_FNEWS_HOST=football-news-aggregator-live.p.rapidapi.com
