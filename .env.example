# ── Supabase (obrigatório em produção) ───────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Modo mock (desenvolvimento sem Supabase) ──────────────────
# VITE_MOCK_AUTH=true

# ── GIFs na Resenha (Tenor API) ───────────────────────────────
# Sem chave: GIFs desabilitados
# VITE_TENOR_KEY=your-tenor-api-key

# ── Busca de jogadores no Perfil (TheSportsDB) ────────────────
# Sem chave: usa chave free '123' (rate-limited)
# VITE_THESPORTSDB_KEY=your-thesportsdb-key

# ── Notícias Copa 2026 na Home ────────────────────────────────
# A chave da World News API é PAGA e NÃO vai mais no frontend (H5).
# Ela agora é um SECRET do Edge Function `news-proxy` (server-side):
#
#   supabase secrets set WORLD_NEWS_API_KEY=your-world-news-api-key
#   # opcional: supabase secrets set WORLD_NEWS_URL=https://api.worldnewsapi.com/search-news
#   supabase functions deploy news-proxy
#
# Sem o secret: o proxy usa fallback server-side via Google News RSS.
# (Removidas as antigas VITE_WORLD_NEWS_API_KEY / VITE_WORLD_NEWS_URL /
#  VITE_FNEWS_* — eram chaves pagas embarcadas no bundle público.)
